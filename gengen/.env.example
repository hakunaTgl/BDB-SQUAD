# AetherOS LLM Configuration
# Environment variables for Hermes model integration

# LLM Provider: ollama (recommended), huggingface, or openai-compatible
LLM_PROVIDER=ollama

# Model name (for Ollama)
# Options: hermes2-pro-mistral:latest, nous-hermes2:latest, dolphin-hermes:latest
LLM_MODEL_NAME=hermes2-pro-mistral:latest

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace model ID (if using huggingface provider)
HF_MODEL_ID=NousResearch/Hermes-2-Pro-Mistral-7B

# Generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# System behavior
# The model is unfiltered by default - it will follow instructions
# creatively while maintaining ethical boundaries
